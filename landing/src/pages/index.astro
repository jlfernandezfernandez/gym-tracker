---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const demoExercises = [
	{ gif: `${base}/media/0025-EIeI8Vf.gif`, name: 'Press banca', sets: '3×8 · 60kg', muscle: 'chest' },
	{ gif: `${base}/media/0032-ila4NZS.gif`, name: 'Peso muerto', sets: '3×6 · 90kg', muscle: 'hamstrings' },
	{ gif: `${base}/media/0043-qXTaZnJ.gif`, name: 'Sentadilla', sets: '3×10 · 70kg', muscle: 'quadriceps' },
	{ gif: `${base}/media/0861-fUBheHs.gif`, name: 'Remo en polea', sets: '3×12 · 50kg', muscle: 'back' },
];

const features = [
	{
		icon: '🧠',
		title: 'Agente, no plantilla',
		description: 'El coach conversa contigo, te pregunta y adapta el entreno a tu día. Hermes, Claude, Codex o cualquier agente MCP.',
	},
	{
		icon: '📱',
		title: 'Mini App de Telegram',
		description: 'Tu progreso, sesiones y récords en una Mini App nativa de Telegram. Sin instalar nada.',
	},
	{
		icon: '🏋️',
		title: '1.324 ejercicios',
		description: 'Catálogo con demostración animada, músculos implicados e instrucciones paso a paso.',
	},
	{
		icon: '📈',
		title: 'Progreso real',
		description: 'Series, pesos, mediciones corporales y récords personales persistidos. El agente los recuerda por ti.',
	},
	{
		icon: '🔌',
		title: 'MCP estándar',
		description: 'FastMCP por Streamable HTTP. API FastAPI + SQLModel + PostgreSQL debajo. Media en MinIO (S3).',
	},
	{
		icon: '🔒',
		title: 'Self-hosted',
		description: 'Tus datos en tu servidor. Docker Compose o Coolify. Open source, licencia MIT.',
	},
];
---

<Layout>
	<!-- HERO -->
	<header class="mx-auto grid max-w-6xl items-center gap-14 px-6 pt-20 pb-16 lg:grid-cols-2 lg:pt-28">
		<div class="text-center lg:text-left">
			<p class="mb-4 text-xs font-bold tracking-[.14em] text-accent uppercase">Open source · Self-hosted · MCP</p>
			<h1 class="text-4xl font-bold tracking-tight text-balance sm:text-6xl">
				Tu entrenador<br />
				<span class="text-accent">vive en Telegram</span>
			</h1>
			<p class="mx-auto mt-6 max-w-xl text-lg text-pretty text-hint lg:mx-0">
				Un agente de IA que te conoce: crea tus entrenos, te guía serie a serie y te abre tu progreso en una Mini App.
				Tú hablas, él apunta.
			</p>
			<div class="mt-10 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
				<a href="https://github.com/jlfernandezfernandez/gym-tracker" class="cta rounded-control bg-accent px-6 py-3 font-semibold text-canvas">
					Ver en GitHub
				</a>
				<a href="#como-funciona" class="cta rounded-control border border-edge bg-surface px-6 py-3 font-semibold text-ink hover:bg-hover">
					Cómo funciona
				</a>
			</div>
		</div>

		<!-- CHAT SIMULATOR -->
		<div class="mx-auto w-full max-w-sm">
			<div class="phone overflow-hidden rounded-[36px] border border-edge bg-surface shadow-card">
				<div class="flex items-center gap-3 border-b border-edge px-4 py-3">
					<div class="grid size-9 place-content-center rounded-pill bg-accent/15 text-lg">🏋️</div>
					<div class="min-w-0 flex-1">
						<p class="text-sm font-semibold text-ink">Gym Coach</p>
						<p class="chat-status text-xs text-accent">en línea</p>
					</div>
					<span class="text-hint">⋮</span>
				</div>
				<div id="chat" class="flex h-[430px] flex-col gap-2.5 overflow-hidden px-3 py-4" aria-hidden="true"></div>
			</div>
			<p class="mt-3 text-center text-xs text-hint">Simulación de una sesión real</p>
		</div>
	</header>

	<!-- CÓMO FUNCIONA -->
	<section id="como-funciona" class="reveal mx-auto max-w-5xl px-6 py-16">
		<h2 class="text-center text-3xl font-bold">Cómo funciona</h2>
		<p class="mx-auto mt-3 max-w-xl text-center text-hint">
			Cualquier agente compatible con MCP se convierte en tu coach. Gym Tracker persiste todo lo demás.
		</p>
		<pre class="mx-auto mt-8 max-w-md overflow-x-auto rounded-card border border-edge bg-surface p-6 text-sm leading-relaxed text-ink shadow-card">
Agente (Hermes, Claude, Codex, ...)
              │ MCP
              ▼
        gym-tracker-mcp
              │ API
              ▼
     gym-tracker + Postgres + MinIO
              │
              ▼
       Mini App de Telegram</pre>
	</section>

	<!-- FEATURES -->
	<section class="reveal mx-auto max-w-5xl px-6 py-16">
		<h2 class="text-center text-3xl font-bold">Todo lo que hace</h2>
		<div class="stagger mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
			{
				features.map((feature) => (
					<div class="rounded-card border border-edge bg-surface p-6 shadow-card">
						<span class="text-2xl">{feature.icon}</span>
						<h3 class="mt-3 text-lg font-semibold text-ink">{feature.title}</h3>
						<p class="mt-2 text-sm text-pretty text-hint">{feature.description}</p>
					</div>
				))
			}
		</div>
	</section>

	<!-- EJERCICIOS -->
	<section class="reveal mx-auto max-w-5xl px-6 py-16">
		<h2 class="text-center text-3xl font-bold">Ejercicios con demostración</h2>
		<p class="mx-auto mt-3 max-w-xl text-center text-hint">
			El agente adjunta la demostración animada de cada ejercicio. Nunca más buscar "cómo se hace el remo Gironda".
		</p>
		<div class="stagger mt-10 grid grid-cols-2 gap-5 sm:grid-cols-4">
			{
				demoExercises.map((exercise) => (
					<div class="excard overflow-hidden rounded-card border border-edge bg-surface shadow-card">
						<img src={exercise.gif} alt={exercise.name} loading="lazy" class="aspect-square w-full bg-white object-cover" />
						<div class="p-3">
							<h3 class="text-sm font-semibold text-ink">{exercise.name}</h3>
							<span class="text-xs text-hint">{exercise.muscle}</span>
						</div>
					</div>
				))
			}
		</div>
	</section>

	<!-- SETUP -->
	<section class="reveal mx-auto max-w-5xl px-6 py-16 text-center">
		<h2 class="text-3xl font-bold">Montar tu propio coach</h2>
		<p class="mx-auto mt-3 max-w-xl text-hint">Dos comandos y un token de bot. Guías para Docker Compose y Coolify en el repo.</p>
		<pre class="mx-auto mt-8 max-w-xl overflow-x-auto rounded-card border border-edge bg-surface p-6 text-left text-sm text-ink shadow-card"><code>cp .env.example .env
docker compose up -d</code></pre>
		<a href="https://github.com/jlfernandezfernandez/gym-tracker" class="cta mt-8 inline-block rounded-control bg-accent px-6 py-3 font-semibold text-canvas">
			Empezar ahora →
		</a>
	</section>

	<footer class="border-t border-edge py-10 text-center text-sm text-hint">
		Gym Tracker · Licencia MIT ·
		<a href="https://github.com/jlfernandezfernandez/gym-tracker" class="text-accent hover:underline">GitHub</a>
	</footer>
</Layout>

<style>
	:root {
		--ease-out-strong: cubic-bezier(0.23, 1, 0.32, 1);
	}

	/* ── CTA buttons: press feedback ── */
	.cta {
		transition: transform 160ms var(--ease-out-strong), background-color 160ms ease;
	}
	.cta:active {
		transform: scale(0.97);
	}

	/* ── Scroll reveal ── */
	.reveal {
		opacity: 0;
		transform: translateY(16px);
		transition: opacity 550ms var(--ease-out-strong), transform 550ms var(--ease-out-strong);
	}
	.reveal.in {
		opacity: 1;
		transform: translateY(0);
	}
	/* stagger children once parent section is in */
	.stagger > * {
		opacity: 0;
		transform: translateY(12px);
		transition: opacity 450ms var(--ease-out-strong), transform 450ms var(--ease-out-strong);
	}
	.reveal.in .stagger > * {
		opacity: 1;
		transform: translateY(0);
	}
	.reveal.in .stagger > *:nth-child(1) { transition-delay: 0ms; }
	.reveal.in .stagger > *:nth-child(2) { transition-delay: 60ms; }
	.reveal.in .stagger > *:nth-child(3) { transition-delay: 120ms; }
	.reveal.in .stagger > *:nth-child(4) { transition-delay: 180ms; }
	.reveal.in .stagger > *:nth-child(5) { transition-delay: 240ms; }
	.reveal.in .stagger > *:nth-child(6) { transition-delay: 300ms; }

	/* ── Chat simulator ── */
	.phone :global(.msg) {
		max-width: 85%;
		border-radius: 16px;
		padding: 9px 12px;
		font-size: 0.875rem;
		line-height: 1.4;
		opacity: 1;
		transform: translateY(0) scale(1);
		transition: opacity 250ms var(--ease-out-strong), transform 250ms var(--ease-out-strong);
	}
	@starting-style {
		.phone :global(.msg) {
			opacity: 0;
			transform: translateY(8px) scale(0.97);
		}
	}
	.phone :global(.msg.coach) {
		align-self: flex-start;
		background: var(--color-hover);
		border: 1px solid var(--color-edge);
		border-bottom-left-radius: 5px;
		color: var(--color-ink);
	}
	.phone :global(.msg.user) {
		align-self: flex-end;
		background: color-mix(in srgb, var(--color-accent) 22%, var(--color-surface));
		border-bottom-right-radius: 5px;
		color: var(--color-ink);
	}

	.phone :global(.typing) {
		display: inline-flex;
		gap: 4px;
		padding: 12px;
	}
	.phone :global(.typing i) {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-hint);
		animation: bounce 1.1s ease-in-out infinite;
	}
	.phone :global(.typing i:nth-child(2)) { animation-delay: 0.15s; }
	.phone :global(.typing i:nth-child(3)) { animation-delay: 0.3s; }
	@keyframes bounce {
		0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
		30% { transform: translateY(-4px); opacity: 1; }
	}

	.phone :global(.workout) {
		align-self: flex-start;
		width: 92%;
		border-radius: 16px;
		border-bottom-left-radius: 5px;
		border: 1px solid var(--color-edge);
		background: var(--color-hover);
		padding: 10px 12px;
		opacity: 1;
		transform: translateY(0) scale(1);
		transition: opacity 250ms var(--ease-out-strong), transform 250ms var(--ease-out-strong);
	}
	@starting-style {
		.phone :global(.workout) {
			opacity: 0;
			transform: translateY(8px) scale(0.97);
		}
	}
	.phone :global(.workout header) {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		color: var(--color-hint);
		margin-bottom: 6px;
	}
	.phone :global(.workout .row) {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 6px 0;
	}
	.phone :global(.workout .row + .row) {
		border-top: 1px solid var(--color-edge);
	}
	.phone :global(.workout img) {
		width: 34px;
		height: 34px;
		border-radius: 9px;
		background: #fff;
		object-fit: cover;
	}
	.phone :global(.workout .row > div) { flex: 1; min-width: 0; }
	.phone :global(.workout .row p) {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-ink);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.phone :global(.workout .row span) {
		font-size: 0.7rem;
		color: var(--color-hint);
	}
	.phone :global(.workout .row em) {
		font-style: normal;
		font-size: 0.66rem;
		font-weight: 700;
		padding: 3px 8px;
		border-radius: var(--radius-pill);
		color: var(--color-ok);
		background: var(--color-ok-bg);
		opacity: 0;
		transform: scale(0.9);
		transition: opacity 220ms var(--ease-out-strong), transform 220ms var(--ease-out-strong);
	}
	.phone :global(.workout .row em.done) {
		opacity: 1;
		transform: scale(1);
	}

	/* ── Exercise cards hover (pointer devices only) ── */
	@media (hover: hover) and (pointer: fine) {
		.excard {
			transition: transform 200ms var(--ease-out-strong);
		}
		.excard:hover {
			transform: translateY(-4px);
		}
	}

	/* ── Reduced motion: keep opacity, drop movement ── */
	@media (prefers-reduced-motion: reduce) {
		.reveal,
		.stagger > * {
			transform: none;
			transition: opacity 200ms ease;
		}
		.phone :global(.msg),
		.phone :global(.workout) {
			transition: opacity 200ms ease;
			transform: none;
		}
		.phone :global(.typing i) {
			animation: none;
		}
	}
</style>

<script>
	// ── Scroll reveal ──
	const revealObserver = new IntersectionObserver(
		(entries) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					entry.target.classList.add('in');
					revealObserver.unobserve(entry.target);
				}
			}
		},
		{ rootMargin: '-80px' },
	);
	document.querySelectorAll('.reveal').forEach((section) => revealObserver.observe(section));

	// ── Chat simulator ──
	const chat = document.getElementById('chat')!;
	const status = document.querySelector('.chat-status')!;
	const base = import.meta.env.BASE_URL;

	const exercises = [
		{ gif: `${base}/media/0025-EIeI8Vf.gif`, name: 'Press banca', sets: '3×8 · 60 kg' },
		{ gif: `${base}/media/0032-ila4NZS.gif`, name: 'Press inclinado', sets: '3×10 · 40 kg' },
		{ gif: `${base}/media/0043-qXTaZnJ.gif`, name: 'Sentadilla', sets: '3×10 · 70 kg' },
		{ gif: `${base}/media/0861-fUBheHs.gif`, name: 'Remo en polea', sets: '3×12 · 50 kg' },
	];

	const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));
	const scrollDown = () => chat.scrollTo({ top: chat.scrollHeight, behavior: 'smooth' });

	function addMessage(kind: 'coach' | 'user', text: string) {
		const bubble = document.createElement('div');
		bubble.className = `msg ${kind}`;
		bubble.textContent = text;
		chat.appendChild(bubble);
		scrollDown();
		return bubble;
	}

	async function showTyping(ms: number) {
		status.textContent = 'escribiendo…';
		const typing = document.createElement('div');
		typing.className = 'msg coach typing';
		typing.innerHTML = '<i></i><i></i><i></i>';
		chat.appendChild(typing);
		scrollDown();
		await sleep(ms);
		typing.remove();
		status.textContent = 'en línea';
	}

	function addWorkoutCard() {
		const card = document.createElement('div');
		card.className = 'workout';
		card.innerHTML =
			'<header>Hoy · Empuje</header>' +
			exercises
				.map(
					(exercise) =>
						`<div class="row"><img src="${exercise.gif}" alt="" loading="lazy"><div><p>${exercise.name}</p><span>${exercise.sets}</span></div><em>hecho ✓</em></div>`,
				)
				.join('');
		chat.appendChild(card);
		scrollDown();
		return card;
	}

	async function playConversation() {
		chat.replaceChildren();

		await sleep(700);
		await showTyping(1100);
		addMessage('coach', 'Buenos días, Jordi 💪 Hoy toca empuje. ¿Cómo vas de tiempo?');

		await sleep(1300);
		addMessage('user', 'Dale, tengo 45 min');

		await showTyping(1000);
		addMessage('coach', 'Perfecto, lo ajusto a 4 ejercicios. Te lo dejo aquí 👇');

		await sleep(600);
		const card = addWorkoutCard();

		for (const check of card.querySelectorAll('em')) {
			await sleep(1000);
			check.classList.add('done');
		}

		await sleep(1100);
		addMessage('user', 'Última serie de banca a 8, me sobraba una 😮‍💨');

		await showTyping(1200);
		addMessage('coach', 'Bien ahí 🔥 Subimos a 62,5 kg la próxima. Todo guardado ✅');

		await sleep(4500);
		playConversation();
	}

	if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		// Static conversation, no loop
		addMessage('coach', 'Buenos días, Jordi 💪 Hoy toca empuje.');
		addMessage('user', 'Dale, tengo 45 min');
		const card = addWorkoutCard();
		card.querySelectorAll('em').forEach((check) => check.classList.add('done'));
		addMessage('coach', 'Bien ahí 🔥 Todo guardado ✅');
	} else {
		playConversation();
	}
</script>
