---
/** Home screen: greeting, active session card and navigation. */
---
<section id="landing" class="screen active">
	<div class="hero">
		<h1 id="landing-greeting">Hola</h1>
		<p id="landing-sub">Cargando sesión...</p>
	</div>
	<div id="active-card" class="card tap" style="display:none"></div>
	<div class="grid" style="margin-top:14px">
		<div class="row">
			<button class="btn ghost" id="open-history">Historial</button>
			<button class="btn ghost" id="open-records">Marcas</button>
			<button class="btn ghost" id="open-profile">Perfil</button>
		</div>
	</div>
</section>
