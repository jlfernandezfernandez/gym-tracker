---
/** Native <dialog> to collect end-of-session feedback (prompt() is unreliable in the Telegram webview). */
---
<dialog id="finish-dialog" class="sheet">
	<h2>Finalizar sesión</h2>
	<p>Cuéntale al coach cómo ha ido (opcional).</p>
	<textarea id="finish-feedback" placeholder="Fácil, duro, molestias, sensaciones..."></textarea>
	<div class="row" style="margin-top:12px">
		<button class="btn ghost" id="finish-cancel">Cancelar</button>
		<button class="btn" id="finish-confirm">✓ Finalizar</button>
	</div>
</dialog>
