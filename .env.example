# =============================================================================
# gym-tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database (PostgreSQL) ---
# In Coolify, this is injected automatically when you link a Postgres service.
# For local dev, use the values from docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://gym_user:gym_pass@db:5432/gym_tracker

# --- Coach agent ---
# Shared secret for the coach MCP (X-Coach-Key header). The MCP server must
# send the same value in GYM_TRACKER_COACH_KEY. If empty, coach access relies
# on Telegram auth being disabled (dev only).
COACH_API_KEY=

# --- Telegram Bot ---
# Token from @BotFather. Required for Telegram InitData validation.
# If left empty, auth is disabled (single-user dev mode — anyone can access).
TELEGRAM_BOT_TOKEN=

# --- App ---
# Host port for the app container (docker compose).
APP_PORT=8000

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated allowed origins (no spaces).
# Set to your Mini App domain in production.
CORS_ORIGINS=*

# --- Garage S3 (object storage for exercise media) ---
# In docker-compose, S3_ENDPOINT is hardcoded to http://garage:3900.
# S3_ACCESS_KEY and S3_SECRET_KEY are auto-generated by garage-init on first
# run — check its output and paste them here for subsequent starts.
# If left empty, the app falls back to local disk storage.
S3_ENDPOINT=http://garage:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=gym-tracker-media
S3_REGION=garage
