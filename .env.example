# =============================================================================
# gym-tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database (PostgreSQL 18) ---
# In Coolify, this is injected from the managed PostgreSQL 18 resource.
# For local dev, Docker Compose provides postgres:18-alpine.
DATABASE_URL=postgresql+asyncpg://gym_user:gym_pass@postgres:5432/gym_tracker

# --- Coach agent ---
# Shared secret for the coach MCP (X-Coach-Key header). The MCP server must
# send the same value in GYM_TRACKER_COACH_KEY. If empty, coach access relies
# on Telegram auth being disabled (dev only).
COACH_API_KEY=

# --- Telegram Bot ---
# Token from @BotFather. Required for Telegram InitData validation.
# If left empty, auth is disabled (single-user dev mode — anyone can access).
TELEGRAM_BOT_TOKEN=

# --- App ---
# Host port for the app container (docker compose).
APP_PORT=8000

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated allowed origins (no spaces).
# Set to your Mini App domain in production.
CORS_ORIGINS=*

# --- MinIO S3 (object storage for exercise media) ---
# Local Compose starts MinIO on http://minio:9000 and creates the bucket from
# the backend at startup. Use strong values in .env; these defaults are dev-only.
MINIO_ROOT_USER=gym-tracker-access-key
MINIO_ROOT_PASSWORD=gym-tracker-secret-key-change-me
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=gym-tracker-access-key
S3_SECRET_KEY=gym-tracker-secret-key-change-me
S3_BUCKET=gym-tracker-media
S3_REGION=us-east-1
