# Copy to .env: cp .env.example .env
# Defaults start a private local instance. Change every value marked CHANGE_ME
# before exposing the Mini App to Telegram.

# Database used by both Compose files.
POSTGRES_USER=gym_user
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD
POSTGRES_DB=gym_tracker

# Required for a real Telegram Mini App. It must be the token of the bot that
# opens the Web App button/menu.
TELEGRAM_BOT_TOKEN=

# Required by the MCP service to call the API. Generate a long random secret.
COACH_API_KEY=

# Public HTTPS origin for Telegram. Keep localhost only for local development.
PUBLIC_APP_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8000

# Bindings are private by default. Put a reverse proxy on the same host in
# front of APP_BIND:APP_PORT for a public Mini App.
APP_BIND=127.0.0.1
APP_PORT=8000
MCP_BIND=127.0.0.1
MCP_PORT=8001

# Runtime behavior.
ENVIRONMENT=development
LOG_LEVEL=INFO
EXERCISE_DATASET_VERSION=v1.0.0

# Only used by compose.production.yml. Pin an immutable release for production.
GYM_TRACKER_VERSION=latest
