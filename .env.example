# =============================================================================
# gym-tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Environment ---
# development | production. Production requires all external services configured.
# Development allows disabled auth when TELEGRAM_BOT_TOKEN is empty.
ENVIRONMENT=development

# --- Database (PostgreSQL 18) ---
# In Coolify, this is injected from the managed PostgreSQL 18 resource.
# For local dev, Docker Compose provides postgres:18-alpine.
# Mandatory in production.
DATABASE_URL=postgresql+asyncpg://gym_user:gym_pass@postgres:5432/gym_tracker

# --- Coach agent ---
# Shared secret for the coach MCP (X-Coach-Key header). The MCP server must
# send the same value in GYM_TRACKER_COACH_KEY. If empty, coach access relies
# on Telegram auth being disabled (dev only).
COACH_API_KEY=

# --- Telegram Bot ---
# Token from @BotFather. Required for Telegram InitData validation.
# If left empty, auth is disabled (single-user dev mode — anyone can access).
TELEGRAM_BOT_TOKEN=

# --- App ---
# Host port for the app container (docker compose).
APP_PORT=8000
# Public URL used in Mini App links generated by the MCP.
# Local default; set this to your reverse-proxy HTTPS URL when exposed.
PUBLIC_APP_URL=http://localhost:8000
# MCP port exposed on localhost for any external agent (Hermes, Claude, Codex...).
MCP_PORT=8001

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated allowed origins (no spaces).
# Set to your Mini App domain in production.
CORS_ORIGINS=http://localhost:8000

# --- MinIO S3 (object storage for exercise media) ---
# Local Compose starts MinIO on http://minio:9000; it uses the S3 access and
# secret values below as its root credentials. The bootstrap creates the bucket
# before the API starts. All S3 settings are mandatory in production.
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=gym-tracker-access-key
S3_SECRET_KEY=gym-tracker-secret-key-change-me
S3_BUCKET=gym-tracker-media
S3_REGION=us-east-1

# --- Exercise dataset ---
# GitHub repository for the exercise dataset (owner/repo format).
# The bootstrap fetches exercises.json from main, stores metadata in PostgreSQL
# and uploads missing media to S3. Nothing is persisted on local disk.
EXERCISE_DATASET_REPOSITORY=jlfernandezfernandez/exercises-dataset-es
