# =============================================================================
# gym-tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database (PostgreSQL) ---
# In Coolify, this is injected automatically when you link a Postgres service.
# For local dev, use the values from docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://gym_user:gym_pass@db:5432/gym_tracker

# --- Telegram Bot ---
# Token from @BotFather. Required for Telegram InitData validation.
# If left empty, auth is disabled (single-user dev mode — anyone can access).
TELEGRAM_BOT_TOKEN=

# --- App config ---
HOST=0.0.0.0
PORT=8000

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated allowed origins (no spaces).
# Set to your Mini App domain in production.
CORS_ORIGINS=*