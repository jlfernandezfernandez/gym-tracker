# Copy to .env before starting compose.production.yml.
# Values below are examples/placeholders, not production secrets.

GYM_TRACKER_VERSION=latest

# PostgreSQL. Keep POSTGRES_PASSWORD URL-safe: letters, numbers, "-" and "_".
POSTGRES_USER=gym_tracker
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=gym_tracker

# Public HTTPS URL of the App, used by Telegram and links sent by the agent.
PUBLIC_APP_URL=https://gym.example.com
APP_PORT=8000
CORS_ORIGINS=https://gym.example.com

# Telegram validation and MCP-to-API authentication.
TELEGRAM_BOT_TOKEN=replace-with-the-token-from-botfather
COACH_API_KEY=replace-with-a-long-random-coach-key

# MinIO credentials. Compose uses these same values as its root credentials.
S3_ACCESS_KEY=replace-with-a-storage-access-key
S3_SECRET_KEY=replace-with-a-long-random-storage-secret
S3_BUCKET=gym-tracker-media
S3_REGION=us-east-1

# The MCP is local-only by default. Connect Hermes/OpenClaw to localhost:8001.
MCP_PORT=8001
LOG_LEVEL=INFO
EXERCISE_DATASET_REPOSITORY=jlfernandezfernandez/exercises-dataset-es
