# MCP server as a standalone Streamable HTTP service, e.g. for local Compose
# or a reverse-proxied deployment.
# Set GYM_TRACKER_API_BASE / GYM_TRACKER_APP_BASE / GYM_TRACKER_COACH_KEY
# in the deployment environment.
FROM python:3.13-slim

WORKDIR /app

# Coolify's healthcheck runner uses curl/wget inside the image.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir "mcp>=1.28,<2" fastmcp

COPY mcp/ ./mcp/
COPY run_mcp.py .

ENV MCP_PORT=8001
EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8001/ready', timeout=3)" || exit 1

CMD ["python", "run_mcp.py"]
